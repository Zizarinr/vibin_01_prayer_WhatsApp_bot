# WhatsApp Session Settings
WA_SESSION_NAME=sholat-bot-ti462025

# Target WhatsApp Groups (comma-separated list of group IDs, e.g., 120363xxxxxxxx@g.us)
# We will whitelist these group IDs for receiving alerts.
TARGET_GROUP_IDS=120363xxxxxxxx@g.us

# Prayer Location Settings (Default: Ponorogo, East Java, Indonesia)
CITY=Ponorogo
COUNTRY=Indonesia
LATITUDE=-7.8652
LONGITUDE=111.4617

# Calculation Method (Kemenag RI method is customized via Fajr 20, Isha 18)
# If using other standard methods, you can configure them here.
PRAYER_METHOD=Kemenag

# Reminder Settings
# Pre-reminder: time in minutes before adzan (set 3 for "3 minutes before adzan")
PRE_REMINDER_MINUTES=3
TIMEZONE=Asia/Jakarta

# Admin Settings
# Whitelisted Admin phone numbers (comma-separated, e.g., 628xxxxxxxxxx)
# Only these numbers can trigger admin commands or receive crash/alert notifications.
ADMIN_PHONES=628xxxxxxxxxx

# Toggle Features (true/false)
ENABLE_HIJRI_DATE=true
ENABLE_HADITH=true
ENABLE_ADMIN_COMMANDS=true
HADITH_TOPIC=sholat_tepat_waktu
