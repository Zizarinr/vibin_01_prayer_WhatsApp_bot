# WhatsApp Session
WA_SESSION_NAME=sholat-bot-session

# Target Groups (comma-separated Group IDs, e.g. 120363xxxxxxxx@g.us)
# Leave empty on first run — bot will list available groups for you to choose.
TARGET_GROUP_IDS=

# Location (default: Ponorogo, East Java, Indonesia)
CITY=Ponorogo
COUNTRY=Indonesia
LATITUDE=-7.8652
LONGITUDE=111.4617

# Calculation Method: Kemenag, Muhammadiyah, or any adhan standard
PRAYER_METHOD=Kemenag

# Pre-reminder minutes before Adhan
PRE_REMINDER_MINUTES=3

# Timezone (Asia/Jakarta, Asia/Makassar, Asia/Jayapura)
TIMEZONE=Asia/Jakarta

# Admin phone numbers (comma-separated, no + or spaces, e.g. 6281234567890)
ADMIN_PHONES=

# Feature toggles (true/false)
ENABLE_HIJRI_DATE=true
ENABLE_HADITH=true
ENABLE_ADMIN_COMMANDS=true
HADITH_TOPIC=sholat_tepat_waktu
